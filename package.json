{
  "name": "koishi-plugin-doubao-image-generation",
  "description": "基于豆包 Seedream 的图片生成插件，支持文生图/图生图，可独立使用或作为 ChatLuna 工具",
  "version": "1.0.2",
  "type": "module",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.mjs",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "dist",
    "locales",
    "presets"
  ],
  "homepage": "https://github.com/Cherylight/koishi-plugin-doubao-image-generation",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cherylight/koishi-plugin-doubao-image-generation.git"
  },
  "contributors": [
    "cherylight"
  ],
  "license": "MIT",
  "keywords": [
    "chatbot",
    "koishi",
    "plugin",
    "image",
    "doubao",
    "seedream",
    "generation",
    "chatluna"
  ],
  "koishi": {
    "description": {
      "zh": "基于豆包 Seedream 的图片生成，支持文生图/图生图与 ChatLuna 工具集成"
    },
    "service": {
      "required": [
        "database"
      ],
      "optional": [
        "chatluna"
      ]
    },
    "locales": [
      "zh-CN"
    ]
  },
  "peerDependencies": {
    "koishi": "^4.18.0"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "koishi-plugin-chatluna": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit false && node build.mjs",
    "build:types": "tsc --noEmit false",
    "prepublishOnly": "npm run build"
  }
}
